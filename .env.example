# Splunk
SPLUNK_HOST=https://your-splunk-host:8089
SPLUNK_USER=admin
SPLUNK_PASS=your_splunk_password
SPLUNK_INDEX=main
LOOKBACK_MINS=60
MAX_LOG_RESULTS=5000
MAX_LLM_CLUSTERS=20

# Drain clustering
DRAIN_SIM=0.5
DRAIN_DEPTH=4
DRAIN_MAX_CHILD=100

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASS=your_app_password
EMAIL_FROM=alerts@yourcompany.com
EMAIL_TO=devteam@yourcompany.com,oncall@yourcompany.com
