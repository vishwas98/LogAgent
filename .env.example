# ── Splunk ────────────────────────────────────────────────────────────────────
SPLUNK_HOST=https://your-splunk-host:8089
SPLUNK_USER=admin
SPLUNK_PASS=your_splunk_password
SPLUNK_INDEX=main
LOOKBACK_MINS=60
MAX_LOG_RESULTS=5000
MAX_LLM_CLUSTERS=20

# ── Context window (time-based, anchored on FIRST error per source stream) ────
# Fetches everything in [first_error - PRE_WINDOW_SECS, first_error + POST_WINDOW_SECS]
# from each log source that produced an error.  Gives the LLM the 5-minute incident
# slice instead of isolated error lines — reveals lead-up and immediate cascade.
PRE_WINDOW_SECS=180     # 3 min before first error  (startup / pressure build-up)
POST_WINDOW_SECS=120    # 2 min after first error   (consequence / recovery)
MAX_CONTEXT_SOURCES=30  # max distinct host+source streams in the batch SPL OR-clause

# ── Continuous daemon ─────────────────────────────────────────────────────────
# POLL_INTERVAL_SECS: how often to query Splunk (should align with LOOKBACK_MINS)
#   3600 = query every hour with a 60-min lookback → no gap, no double-counting
# DEDUP_WINDOW_MINS: suppress re-alerting on the *same* cluster pattern within N minutes
#   120 = if ERROR pattern X was already reported, skip it for the next 2 hours.
#   This prevents hourly spam for a persistent error that hasn't been fixed yet.
#   Set to 0 to disable deduplication (alert every cycle for every cluster).
POLL_INTERVAL_SECS=3600  # poll every 1 hour
DEDUP_WINDOW_MINS=120    # suppress repeat alerts for 2 hours

# ── Drain clustering ──────────────────────────────────────────────────────────
DRAIN_SIM=0.5
DRAIN_DEPTH=4
DRAIN_MAX_CHILD=100
MERGE_SIM=0.8

# ── LLM token budget ──────────────────────────────────────────────────────────
LLM_BUDGET_CHARS=3500    # hard cap on user-message chars per cluster call (~875 tokens)
MAX_SLOT_VALS=5          # max dynamic values tracked per variable slot

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub codebase context (optional but strongly recommended) ───────────────
# Enables codebase-aware RCA: agent reads your main branch once at startup,
# builds an architecture summary (cached LLM system block), then injects
# relevant code snippets into each cluster's RCA prompt.
#
# The codebase index is refreshed once per day at CODEBASE_REFRESH_HOUR Eastern Time.
# This captures overnight / early-morning deploys before business hours begin.
# Deploys during business hours (7 AM – 6 PM ET) are excluded by team convention,
# so a single morning refresh is sufficient — no GitHub API calls during other hours.
#
# Note: install the 'tzdata' PyPI package on Windows for DST-aware Eastern Time.
# Without it the agent falls back to a fixed UTC-5 offset (no DST correction).
GITHUB_TOKEN=ghp_...                  # Personal access token (read:contents scope)
GITHUB_REPO=owner/your-app-repo       # The application repo producing the Splunk logs
GITHUB_BRANCH=main
MAX_ARCH_CHARS=6000        # chars of architecture context in system block
MAX_SNIPPET_CHARS=2000     # chars of per-cluster code snippet injected into user prompt
CODEBASE_REFRESH_HOUR=7    # hour (0-23) in Eastern Time to re-index the codebase daily

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASS=your_app_password
EMAIL_FROM=alerts@yourcompany.com
EMAIL_TO=devteam@yourcompany.com,oncall@yourcompany.com
